   "source": [
    "def factorial(n):\n",
    "    if n==0 or n==1:\n",
    "        return 1\n",
    "    else:\n",
    "        return n*factorial(n-1)\n",
    "a=int(input(\"Enter a number:\"))\n",
    "result=factorial(a)\n",
    "print(result)\n"
   ]
  }
