   "source": [
    "def fibonacci(n):\n",
    "   dp = [0] * (n + 1)\n",
    "\n",
    "   dp[0] = 0\n",
    "   if n > 0:\n",
    "       dp[1] = 1\n",
    "\n",
    "   for i in range(2, n + 1):\n",
    "       dp[i] = dp[i - 1] + dp[i - 2]\n",
    "\n",
    "   return dp[n]\n",
    "\n",
    "# Driver Code\n",
    "n = int(input(\"Enter n: \"))\n",
    "print(\"Fibonacci Number =\", fibonacci(n))"
   ]
  }
 ],
